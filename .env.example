# PostgreSQL 数据库连接
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mymem

# LLM Provider: openai | anthropic
LLM_PROVIDER=openai

# OpenAI 配置
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_BASE_URL=https://api.openai.com/v1  # 可选，用于代理或兼容 API
OPENAI_PROXY=  # 代理配置：留空=禁用代理，不设置=使用系统代理，或填写代理地址如 http://127.0.0.1:7890

# Anthropic 配置（如果使用 Claude）
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# 向量模型配置
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# JWT 配置
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# 记忆配置
FORGETTING_THRESHOLD=30  # 遗忘系数（天）
MAX_CATEGORY_SUMMARY_LENGTH=2000
